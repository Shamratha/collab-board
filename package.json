{
  "name": "collab-board",
  "version": "0.1.0",
  "private": true,
  "description": "CollabBoard — a collaborative real-time project board (mini Linear/Trello). MERN + Socket.io.",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "test": "npm run test --workspace server",
    "start": "npm run start --workspace server"
  },
  "engines": {
    "node": ">=20"
  }
}
